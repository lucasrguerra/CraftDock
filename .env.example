# Auth
ADMIN_PASSWORD_HASH=
SESSION_SECRET=change-me-to-a-long-random-string

# Minecraft target
MC_CONTAINER_NAME=craftdock-mc-server
MC_DATA_PATH=/minecraft/data
MC_EDITION=auto            # auto | java | bedrock
MC_WORLD_NAME=world        # world folder name inside MC_DATA_PATH

# RCON (Java)
RCON_HOST=craftdock-mc-server
RCON_PORT=25575
RCON_PASSWORD=

# Map tab (optional)
MAP_URL=                   # self-hosted map to embed instead of mcseedmap (must allow iframe embedding)
MAP_VERSION=               # mcseedmap version override, e.g. 1.21-Java or 26.30.0-Bedrock

# App
PORT=3000
NODE_ENV=production
LOG_LEVEL=info             # error | warn | info | debug
MAX_UPLOAD_MB=1024
