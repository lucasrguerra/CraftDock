# CraftDock environment — every variable the app reads (see src/config.js).
# Copy to .env and fill in. Full descriptions are in the README env-var table.

# --- Auth (required) ---
# Generate both forms with: npm run hash -- <your-password>. Set exactly ONE.
#   ADMIN_PASSWORD_HASH      raw bcrypt hash — use with `npm run dev` (plain .env)
#   ADMIN_PASSWORD_HASH_B64  base64 of the hash — use with docker compose / Coolify
#                            (bcrypt hashes contain `$`, which those interpolate)
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_HASH_B64=
SESSION_SECRET=change-me-to-a-long-random-string

# --- Minecraft target ---
MC_CONTAINER_NAME=craftdock-mc-server   # container name (matched first)
MC_SERVICE_NAME=minecraft-server        # compose service name (fallback when the
                                        # container name is auto-generated, e.g. Coolify)
MC_DATA_PATH=/minecraft/data            # shared mc-data volume path inside the panel
MC_EDITION=auto                         # auto | java | bedrock
MC_WORLD_NAME=world                     # world folder under MC_DATA_PATH (Bedrock: worlds)

# --- RCON (Java only; leave empty for Bedrock) ---
RCON_HOST=craftdock-mc-server
RCON_PORT=25575
RCON_PASSWORD=

# --- Map tab (optional) ---
MAP_VERSION=                            # mcseedmap version override, e.g. 1.21-Java or 26.30.0-Bedrock

# --- App ---
PORT=3000
NODE_ENV=production                     # use `development` for plain-http local testing
LOG_LEVEL=info                          # error | warn | info | debug
MAX_UPLOAD_MB=1024
